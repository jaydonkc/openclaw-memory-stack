# Milvus
MILVUS_URI=http://127.0.0.1:19530
MILVUS_COLLECTION=openclaw_memory

# Embeddings (default: local Ollama + nomic-embed-text)
# EMBED_PROVIDER: sentence-transformers | openai
EMBED_PROVIDER=openai
EMBED_MODEL=nomic-embed-text
# For EMBED_PROVIDER=openai (OpenAI-compatible endpoint; Ollama default)
EMBED_BASE_URL=http://127.0.0.1:11434/v1
EMBED_API_KEY=ollama

# Rollup scheduling (used by scripts/install_cron.sh)
ROLLUP_ENABLE_DAILY=1
ROLLUP_ENABLE_WEEKLY=1
# UTC cron expressions
ROLLUP_DAILY_CRON=0 2 * * *
ROLLUP_WEEKLY_CRON=0 3 * * 0

# File roots (edit for your machine)
MAIN_WORKSPACE=/home/<you>/.openclaw/workspace
CODING_WORKSPACE=/home/<you>/.openclaw/workspace-coding
SHARED_MEMORY_FILE=/home/<you>/.openclaw/shared/SHARED_MEMORY.md
