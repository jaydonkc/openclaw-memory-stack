# Milvus
MILVUS_URI=http://127.0.0.1:19530
MILVUS_COLLECTION=openclaw_memory

# Embeddings
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# File roots (edit for your machine)
MAIN_WORKSPACE=/home/<you>/.openclaw/workspace
CODING_WORKSPACE=/home/<you>/.openclaw/workspace-coding
SHARED_MEMORY_FILE=/home/<you>/.openclaw/shared/SHARED_MEMORY.md
